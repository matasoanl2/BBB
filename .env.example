# ============================================================================
# BuyBayBye - Environment Configuration File (.env)
# ============================================================================
# Это файл с переменными окружения для настройки приложения
# 
# ИСПОЛЬЗОВАНИЕ:
#   Linux/Mac: Переменные загружаются автоматически из .env
#   Windows:   set переменные вручную или используйте .env парсер
#   Docker:    Помещайте дополнительные переменные в docker-compose.yml
# ============================================================================

# --- PostgreSQL Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=buybaybye

# Путь для хранения JSON файлов экспорта (если нужен экспорт)
EXPORT_PATH=./exports

# Переключатель упрощённой операторской версии dashboard.
# false = текущий dashboard v1 по умолчанию, true = включить dashboard v2.
DASHBOARD_V2_ENABLED=false

# Пул подключений PostgreSQL для dashboard
# Минимум и максимум физических соединений, переиспользуемых между API-запросами
DASHBOARD_DB_POOL_MIN_CONN=1
DASHBOARD_DB_POOL_MAX_CONN=10

# ============================================================================
# --- Browser & Display Configuration ---
# ============================================================================

# Таймзона контейнеров и Python-процессов
# Для московского времени оставьте Europe/Moscow
TZ=Europe/Moscow

# Режим без видимого окна браузера
# true  = headless режим (без окна, экономит ресурсы, для Docker)
# false = видимое окно браузера (удобно для отладки, локальный запуск)
HEADLESS=true

# Размер области общей памяти для браузера (shared memory in Docker)
# Значения: "1gb", "2gb", "4gb" и т.д.
# Важно! Недостаточно памяти → крахи браузера
BROWSER_SHM_SIZE=1gb

# Отладка при размещении ставок
# true  = выводит полные детали запроса/ответа для каждой ставки
# false = выводит только результат (успех/ошибка)
BET_DEBUG_ENABLED=false

# Логировать HTTP POST batch-ставки через bet_system лог (plain/json по TERMINAL_JSON_LOGS)
# true  = печатать запрос (url/slot/round/targets/sum/payload) и ответ (status/body preview)
# false = отключено
BET_POST_LOG_ENABLED=false

# Отправлять slot1 + slot2 одним общим HTTP POST (payload {"bets":[...]})
# true  = при активном slot2 и целях для обоих слотов отправляется один объединенный POST
# false = стандартный режим: раздельные POST для slot1 и slot2
BET_COMBINE_SLOTS_IN_SINGLE_POST=false

# Печатать расширенный блок статистики комбинаций каждые {DYNAMIC_RECALC_INTERVAL} ставок
# true  = выводить блок "🎲 СТАТИСТИКА КОМБИНАЦИЙ..."
# false = полностью отключить этот блок в терминале
DICE_STATS_REPORT_ENABLED=false

# Цветной вывод в консоль
# true  = использует ANSI цвета для логов (зелёный для успеха, красный для ошибок, и т.д.)
# false = выводит логи без цветов (монохромный режим)
COLOR_ENABLED=true

# Plain-режим терминальных логов для Grafana/Loki
# true  = только полезный текст без emoji и ANSI-цветов в BET-логах
# false = обычный человекочитаемый формат с таблицей и emoji
TERMINAL_PLAIN_LOGS=false

# JSON one-line режим терминальных логов для Grafana/Loki
# true  = BET-логи в JSON на одной строке (удобно для структурного парсинга)
# false = режим отключен
# Приоритет выше TERMINAL_PLAIN_LOGS (если включены оба, используется JSON one-line)
TERMINAL_JSON_LOGS=false

# Принудительно считать эмодзи (🔴, 🟡, 🧰 и т.д.) как 2 символа ширины
# true  = фиксированная ширина 2 (может помочь в некоторых терминалах)
# false = авто-определение ширины через wcwidth/терминал (рекомендуется)
FORCE_DOUBLE_WIDTH_EMOJI=true

# Блокировать загрузку видеопотока в браузере (экономия трафика/CPU)
# true  = блокировать media-запросы и HLS/MP4/WebM сегменты
# false = не вмешиваться в загрузку видео
BROWSER_BLOCK_VIDEO_STREAM=false

# ============================================================================
# --- Betting Mode Configuration ---
# ============================================================================

# Включить/отключить автоматическое размещение ставок
# ВНИМАНИЕ: true = будут размещаться РЕАЛЬНЫЕ ставки на РЕАЛЬНЫЕ деньги!
BET_MODE=true

# Проверять required bank стратегии перед первым шагом
# true  = если real balance неизвестен/меньше required bank, первый шаг ставится на паузу
# false = проверка required bank отключена, первый шаг не блокируется этой проверкой
CHECK_REQUIRED_BANK_ON_FIRST_STEP=true

# Цели ставок на один раунд
# Формат: список через запятую из R1-R6, Y1-Y6 и D
#   R1 = красный 1
#   Y3 = жёлтый 3
#   D  = любой дубль
# Все цели из списка отправляются одним HTTP-запросом в один и тот же раунд
# BET_TARGETS=R2,R3,R4,R5,Y2,Y3,Y4,Y5
# BET_TARGETS=R2,R3,R4,R5
BET_TARGETS=R3

# Базовая ставка в рублях
# ОБЯЗАТЕЛЬНО: должна делиться на 10 нацело!
# ✓ Правильные: 10, 20, 30, 40, 50, 100, 200...
# ✗ НЕПРАВИЛЬНЫЕ: 15, 25, 35, 45, 75...
# Значение ниже 10 может быть заблокировано сайтом
BASE_BET=10

# Остановить автоставки при достижении real balance этого значения (в рублях)
# 0 = отключено (по умолчанию)
# >0 = как только real balance >= этого порога, новые ставки не размещаются
STOP_AT_BALANCE=0

# Интервал проверки (в секундах) после остановки по STOP_AT_BALANCE.
# Если за этот интервал real balance снизился, ставки возобновляются с шага 1.
STOP_AT_BALANCE_RESUME_CHECK_SECONDS=300

# ============================================================================
# --- Strategy Selection ---
# ============================================================================

# Выбор стратегии ставок по имени файла (без расширения .yaml)
# 
# БАЗОВЫЕ СТРАТЕГИИ (рекомендуется подавляющему большинству):
#   martingale_classic        - Классическая прогрессия (⭐ рекомендуется)
#   fibonacci_aggressive      - Прогрессия Фибоначчи (быстрое восстановление)
#   flat_betting              - Одинаковая ставка (самая безопасная)
#   balanced                  - Сбалансированная (хороший баланс)
#
# РАСШИРЕННЫЙ ВЫБОР (18 стратегий в папке strategies/):
#   dalambert                 - Линейная прогрессия (низкий риск)
#   exponential               - Экспоненциальный рост (среднее)
#   ultra_aggressive          - Максимальный рост (очень рискованно)
#   conservative_stepped      - Осторожная прогрессия (консервативная)
#   cycle_recovery            - Циклическая прогрессия
#   doubling_cycle            - Удваивающиеся циклы
#   paroli                    - Reverse Martingale (увеличение при победе)
#   system_1_3_2_6            - 1-3-2-6 классическая последовательность
#   oscars_grind              - Oscar's Grind (консервативное восстановление)
#   bell_curve_progressive    - Bell Curve (симметричная кривая)
#   labouchere_modified       - Labouchere (система вычеркивания)
#   cycle_recovery_absolute   - Абсолютная циклическая (enhanced)
#   cycle_recovery_long       - Длинная циклическая (15 шагов)
#   cycle_recovery_rage       - Rage recovery (агрессивная циклическая)
#
STRATEGY=cycle_recovery

# ============================================================================
# --- Второй слот ставок (опционально) ---
# ============================================================================
#
# Если задать STRATEGY_2 + BASE_BET_2 + BET_TARGETS_2, в каждом раунде будет
# размещаться дополнительная независимая ставка с отдельной стратегией и
# своим собственным прогрессом шагов.
#
# Пример: одновременно ставить на Y2 по cycle_recovery_y6_refined_25_1500
#         и на R3 по cycle_recovery с другим BASE_BET.
#
# Оставь пустым или закомментируй — второй слот не активируется.
#
# STRATEGY_2=
# BASE_BET_2=10
# BET_TARGETS_2=Y2

# ============================================================================
# --- Dynamic Betting Mode Configuration ---
# ============================================================================

# Включить динамический режим изменения ставок на основе статистики
# true  = анализирует последние N ставок и автоматически меняет одну активную цель
#         (игнорируется, если в BET_TARGETS указано несколько целей)
# false = использует BET_TARGETS как задано выше
#
# ПРИМЕРЫ АНАЛИЗА:
#   За последние 50 ставок:
#    - red_3:   W=8/15 (53.3%) ← выбирается эта
#    - yellow_5: W=5/12 (41.7%)
#    - 👯:  W=2/13 (15.4%)
# Система переключится на red_3 и будет ставить туда
DYNAMIC_BET_MODE=true

# Включить отдельный dynamic-режим для второго слота ставок (BET_TARGETS_2)
# true  = слот 2 пересчитывает цель динамически (single/multi по общим правилам dynamic)
# false = слот 2 работает по фиксированным BET_TARGETS_2
DYNAMIC_BET_MODE_2=false

# Разрешить dynamic режим для multi-target (когда в BET_TARGETS несколько целей)
# true  = dynamic будет выбирать N целей из окна, где N = количество BET_TARGETS
# false = dynamic работает только для одиночной цели
DYNAMIC_MULTI_TARGET_ENABLED=false

# Сохранять цветовой состав целей (red/yellow/double) как в исходном BET_TARGETS
# true  = при dynamic multi-target стараемся сохранить количественное соотношение цветов
# false = выбираем просто топ-N комбинаций по частоте
DYNAMIC_PRESERVE_COLOR_RATIO=false

# Запретить dynamic режиму менять цвет кубика
# true  = dynamic меняет только цифру, цвет остаётся как в BET_TARGETS
# false = dynamic может выбрать любой цвет (включая смену red ↔ yellow)
DYNAMIC_LOCK_COLOR=false

# Размер окна для анализа статистики (количество последних ставок для анализа)
# 40 ставок - хороший баланс между скоростью адаптации и стабильностью
# Диапазон: 20-100 (меньше = быстрая адаптация, больше = стабильнее)
DYNAMIC_WINDOW_SIZE=10

# Как часто пересчитывать оптимальную ставку (в количестве ставок)
# 1 = каждый ход (для тестирования)
# 5 = каждые 5 ставок пересчитываем и может быть меняем стратегию
# 10 = меньше чаще, но более совершённых ставок
DYNAMIC_RECALC_INTERVAL=5

# Показывать блок "ДИНАМИЧЕСКОЕ ОБНОВЛЕНИЕ СТАВКИ" при реальной смене dynamic-цели
# true  = выводить блок обновления в терминал
# false = скрыть блок обновления, оставив сам dynamic mode рабочим
DYNAMIC_UPDATE_OUTPUT_ENABLED=false

# Показывать блок "АНАЛИЗ ДИНАМИЧЕСКОЙ СТАВКИ", если ставка не изменилась
# true  = выводить аналитический блок в терминал
# false = скрыть этот блок, оставив только сообщения о реальной смене ставки
DYNAMIC_UNCHANGED_ANALYSIS_OUTPUT_ENABLED=false

# Как выбирать число для динамической ставки
# true  = для red/yellow брать значение, ближайшее к среднему значению кубика за окно анализа
# false = выбирать просто самую частую комбинацию color+value
DYNAMIC_USE_AVERAGE_VALUE_SELECTION=false

# Участвует ли ставка на double в динамическом выборе
# true  = double сравнивается с red/yellow как отдельный кандидат
# false = выбор идет только между red/yellow
DYNAMIC_INCLUDE_DOUBLE_SELECTION=false

# Быстрые режимы настройки:
# 1) Старое поведение:
#    DYNAMIC_USE_AVERAGE_VALUE_SELECTION=false
#    DYNAMIC_INCLUDE_DOUBLE_SELECTION=true
# 2) Среднее значение + double:
#    DYNAMIC_USE_AVERAGE_VALUE_SELECTION=true
#    DYNAMIC_INCLUDE_DOUBLE_SELECTION=true
# 3) Только среднее по цветам, без double:
#    DYNAMIC_USE_AVERAGE_VALUE_SELECTION=true
#    DYNAMIC_INCLUDE_DOUBLE_SELECTION=false
# 4) Только самая частая цветная комбинация, без double:
#    DYNAMIC_USE_AVERAGE_VALUE_SELECTION=false
#    DYNAMIC_INCLUDE_DOUBLE_SELECTION=false

# Дополнительные фильтры динамической системы
# Они ограничивают окно анализа перед выбором новой ставки.
# Если оба выключены, анализируются все подходящие исторические раунды.

# Учитывать имя текущего игрока при пересчете динамической ставки
# true  = анализировать только исторические раунды этого же игрока
# false = анализировать все раунды без фильтра по игроку
DYNAMIC_FILTER_BY_PLAYER=false

# Учитывать сторону игрока (left/right) при пересчете динамической ставки
# true  = анализировать только исторические раунды той же стороны
# false = анализировать все раунды без фильтра по стороне
DYNAMIC_FILTER_BY_SIDE=true

# Примеры фильтрации:
# player only                  -> true / false
# side only                    -> false / true
# player + side                -> true / true
# no filters                   -> false / false
DYNAMIC_RANDOM_FALLBACK_ENABLED=false
DYNAMIC_RANDOM_FALLBACK_LOSS_STREAK=20

# ============================================================================
# --- Accounting WS Balance Monitoring ---
# ============================================================================

# Через сколько секунд считать real balance устаревшим,
# если по accounting_ws не пришло ожидаемое обновление после ставки
ACCOUNTING_BALANCE_STALE_SECONDS=30

# Отключает recovery reload только по stale balance, не затрагивая другие recovery-триггеры
ACCOUNTING_RECOVERY_RELOAD_ON_STALE_BALANCE=false

# Через сколько секунд после открытия accounting_ws запускать recovery,
# если НЕ пришел ни один валидный initial balance_update (даже если приходят ping)
ACCOUNTING_INITIAL_BALANCE_TIMEOUT_SECONDS=20

# Через сколько секунд после stale-состояния пробовать восстановление
# через reload страницы
ACCOUNTING_RECOVERY_RELOAD_SECONDS=60

# Минимальная пауза между попытками recovery, чтобы не перезагружать страницу слишком часто
ACCOUNTING_RECOVERY_COOLDOWN_SECONDS=60

# Порог idle-reconnect для accounting_ws:
# если соединение формально открыто, но долго нет сообщений, выполняется recovery через reload
# (работает как отдельный триггер, даже если нет stale-сценария по balance_update)
ACCOUNTING_IDLE_RECONNECT_SECONDS=300

# После скольких подряд page crash во время recovery останавливать процесс,
# чтобы внешний оркестратор (Docker/systemd) выполнил чистый рестарт.
ACCOUNTING_PAGE_CRASH_RESTART_THRESHOLD=3

# Интервал опроса health-monitor для accounting_ws
ACCOUNTING_MONITOR_POLL_SECONDS=3

# Логировать причины, по которым accounting_ws сообщения были отброшены
# true  = печатать [ACCOUNTING][SKIP] ... в консоль
# false = только хранить последнюю причину во внутреннем состоянии
ACCOUNTING_DEBUG_REJECTED_MESSAGES=false

# ============================================================================
# --- Telegram Notifications ---
# ============================================================================

# Включить уведомления в Telegram
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Узнать TELEGRAM_CHAT_ID:
#   python main.py telegram-chat-id
# Затем написать боту /chatid или любое сообщение

TELEGRAM_REQUEST_TIMEOUT_SECONDS=5
TELEGRAM_NOTIFICATION_COOLDOWN_SECONDS=120
TELEGRAM_NOTIFY_DEPOSITS=true
TELEGRAM_NOTIFY_WITHDRAWALS=true
TELEGRAM_NOTIFY_ACCOUNTING_ISSUES=true
TELEGRAM_NOTIFY_BET_ERRORS=true
TELEGRAM_NOTIFY_AUTH_ISSUES=true

# ============================================================================
# --- Betting Delay Configuration ---
# ============================================================================

# Минимальная задержка ПЕРЕД размещением ставки (в секундах)
# Чем выше, тем медленнее, но человечнее
# Рекомендуемый диапазон: 0.5-2.0
BET_DELAY_MIN=0.8

# Максимальная задержка ПЕРЕД размещением ставки (в секундах)
# Диапазон: [BET_DELAY_MIN, BET_DELAY_MAX]
# Каждая ставка будет с задержкой random(BET_DELAY_MIN, BET_DELAY_MAX)
BET_DELAY_MAX=1.5

# ============================================================================
# --- Profile & Backup Configuration ---
# ============================================================================

# Путь для хранения профиля браузера (cookies, tokens, etc.)
PROFILE_DIR=./profile

# Путь для хранения резервных копий профиля
BACKUPS_DIR=./profile_backups

# Автоматическое сохранение профиля при каждом закрытии браузера
# true  = автоматически сохранять
# false = не сохранять
AUTO_SAVE_PROFILE=true

# ============================================================================
# --- Logging & Debug Configuration ---
# ============================================================================

# Уровень логирования
# Варианты: "debug", "info", "warning", "error", "critical"
LOG_LEVEL=info

# Сохранять ли логи в файл
# true  = сохранять в ./logs/app.log
# false = только в консоль
LOG_TO_FILE=true

# Максимальный размер лог-файла в МБ перед ротацией
LOG_FILE_MAX_SIZE=10

# Количество архивных лог-файлов для сохранения
LOG_FILES_BACKUP_COUNT=5

# Логирование WebSocket соединений и сообщений
# true  = выводить в консоль все WS сообщения (VERBOSE)
# false = логирование отключено
WS_LOG_ENABLED=false

# ============================================================================
# --- Advanced/Experimental Features ---
# ============================================================================

# Использование VPN/Proxy (если требуется)
# Оставьте пустым для отключения
# Формат: "http://proxy-host:proxy-port"
HTTP_PROXY=

HTTPS_PROXY=

# ============================================================================
# --- ПРИМЕРЫ ИСПОЛЬЗОВАНИЯ ---
# ============================================================================

# ПРИМЕР 1: Только сбор данных (без ставок)
# BET_MODE=false python main.py

# ПРИМЕР 2: Martingale с реальными ставками
# BET_MODE=true STRATEGY=martingale_classic BASE_BET=10 python main.py

# ПРИМЕР 3: Flat betting
# BET_MODE=true STRATEGY=flat_betting BASE_BET=20 python main.py

# ПРИМЕР 4: Fibonacci агрессивная, Docker
# docker-compose -f docker-compose.yml up -d
# (используйте переменные в docker-compose.yml)

# ПРИМЕР 5: Анализ данных
# python analys_comprehensive.py

# ПРИМЕР 6: Анализ со ВСЕМИ данными из БД
# python analys_comprehensive.py --time-filter all

# ПРИМЕР 7: Быстрый анализ (последние 3 часа)
# python analys_comprehensive.py --time-filter 3hours

# ПРИМЕР 7b: Анализ с гибким фильтром времени (любой период)
# python analys_comprehensive.py --time-filter 1hour
# python analys_comprehensive.py --time-filter 6hours
# python analys_comprehensive.py --time-filter 1day
# python analys_comprehensive.py --time-filter 7days
# python analys_comprehensive.py --time-filter 1week
# python analys_comprehensive.py --time-filter 1month

# ПРИМЕР 7c: Анализ периодичности (только периодичность выпадений)
# python analys_comprehensive.py --mode periodicity --time-filter all

# ПРИМЕР 7d: Полный анализ с периодичностью и гибким временем
# python analys_comprehensive.py --mode combined --time-filter 3hours
# python analys_comprehensive.py --mode combined --time-filter 1day

# ПРИМЕР 8: Ставка на ДУБЛЬ (любой) с консервативной стратегией
# BET_MODE=true BET_TARGETS=D STRATEGY=oscars_grind BASE_BET=10 python main.py

# ПРИМЕР 9: Ставка на ДУБЛЬ (любой) с обратной Martingale
# BET_MODE=true BET_TARGETS=D STRATEGY=paroli BASE_BET=20 python main.py

# ПРИМЕР 10: Экспорт из БД в JSON
# python import_export.py export ./exports

# ============================================================================
# --- ВАЖНЫЕ ЗАМЕЧАНИЯ ---
# ============================================================================

# 1. BASE_BET MUST BE DIVISIBLE BY 10
#    Система проверяет: BASE_BET % 10 == 0
#    Неправильно: 15, 25, 35, 45...
#    Правильно: 10, 20, 30, 40...

# 2. РЕАЛЬНЫЕ ДЕНЬГИ И РИСК
#    BET_MODE=true означает размещение РЕАЛЬНЫХ ставок на РЕАЛЬНЫЕ деньги!
#    Убедитесь что понимаете все риски перед включением.

# 3. ПРОФИЛЬ БРАУЗЕРА
#    Сохраняется при закрытии приложения (нажмите Enter или закройте браузер).
#    Используется для входа БЕЗ повторной авторизации при следующих запусках.

# 4. ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
#    Linux/Mac: export VAR=value && python main.py
#    Windows PS: $env:VAR="value"; python main.py
#    Docker: переменные в docker-compose.yml или .env в контексте docker-compose

